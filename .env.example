# Copy this to .env and fill in your values
# cp .env.example .env

# ─── Kotak Neo API Credentials ───────────────────────────────────────────────
KOTAK_CONSUMER_KEY=your_consumer_key
KOTAK_CONSUMER_SECRET=your_consumer_secret
KOTAK_ACCESS_TOKEN=your_access_token
KOTAK_MOBILE_NUMBER=+91XXXXXXXXXX
KOTAK_UCC=XXXXXX
KOTAK_DEMAT_ACCOUNT=XXXXXXXX
KOTAK_CLIENT_EMAIL=your@email.com
KOTAK_MPIN=your_mpin
KOTAK_TOTP_SECRET=your_totp_secret
KOTAK_IP_WHITELIST=your_server_ip

# ─── Telegram Alerts ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_CHAT_ID_2=optional_second_chat_id

# ─── Anthropic AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key

# ─── Trading Config ───────────────────────────────────────────────────────────
PAPER_TRADING=true
MAX_CAPITAL=100000
MAX_POSITION_SIZE_PCT=10
MAX_DAILY_LOSS_PCT=3
MAX_OPEN_POSITIONS=5
